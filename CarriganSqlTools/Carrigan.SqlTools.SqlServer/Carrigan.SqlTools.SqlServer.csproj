<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Carrigan.SqlTools.SqlServer</PackageId>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <DebugType>portable</DebugType>
    <DebugSymbols>true</DebugSymbols>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>


    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <PropertyGroup>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <GeneratePackageOnBuild Condition="'$(Configuration)'=='Release'">True</GeneratePackageOnBuild>
    <PackageReadmeFile>readme.md</PackageReadmeFile>

    <Description>
      Carrigan.SqlTools.SqlServer is a companion library to Carrigan.SqlTools, focused on executing SQL Server queries at runtime.

      It provides a wrapper around ADO.NET that makes it easier to run the queries generated by Carrigan.SqlTools. It also includes support for working with the SqlInvoker, which can take a Dictionary&gt;string, object=""?&lt; representing a SQL row and create an object instance with those values.

      In addition, the library handles decryption of encrypted properties when encryption logic has been defined through the interfaces and attributes provided by Carrigan.Core.

      Together with Carrigan.SqlTools, this library provides a full workflow for generating, executing, and consuming SQL Server queries with object-oriented protections.
    </Description>
    <PackageTags>
        sql;sqlserver;ado.net;database;crud;query-execution;object-mapper;
        reflection;encryption;attributes;invoker;carrigan;dotnet;library
    </PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Carrigan.Core" Version="0.1.0-alpha.202601172327" />
    <PackageReference Include="Microsoft.Data.SqlClient" Version="6.1.4" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Carrigan.SqlTools\Carrigan.SqlTools.csproj" />
  </ItemGroup>


  <ItemGroup>
    <None Include="readme.md" Pack="true" PackagePath="\" />
    <None Include="Acknowledgements.txt" Pack="true" PackagePath="\" />
    <None Include="NOTICE.txt" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
