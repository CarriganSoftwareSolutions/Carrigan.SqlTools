<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Carrigan.SqlTools.Clients.SqlServer</PackageId>
    <TargetFrameworks>net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <DebugType>portable</DebugType>
    <DebugSymbols>true</DebugSymbols>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>


    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <PropertyGroup>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <GeneratePackageOnBuild Condition="'$(Configuration)'=='Release'">True</GeneratePackageOnBuild>
    <PackageReadmeFile>readme.md</PackageReadmeFile>

    <Description>
      Carrigan.SqlTools.Clients.SqlServer is a companion library to Carrigan.SqlTools.Generators.SqlServer, focused on executing SQL Server queries at runtime.

      It provides a wrapper around ADO.NET that makes it easier to run the queries generated by Carrigan.SqlTools.Generators.SqlServer. It also uses the shared invocation infrastructure to create model instances from SQL Server result rows.

      In addition, the library handles decryption of encrypted properties when encryption logic has been defined through the interfaces and attributes provided by Carrigan.Core.

      Together with Carrigan.SqlTools.Generators.SqlServer, this library provides a full workflow for generating, executing, and consuming SQL Server queries with object-oriented protections.
    </Description>
    <PackageTags>
        sql;sqlserver;ado.net;database;crud;query-execution;object-mapper;
        reflection;encryption;attributes;invoker;carrigan;dotnet;library
    </PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Carrigan.Core" Version="0.1.4" />
    <PackageReference Include="Microsoft.Data.SqlClient" Version="7.0.1" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="10.0.300" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Carrigan.SqlTools.Clients.Core\Carrigan.SqlTools.Clients.Core.csproj" />
    <ProjectReference Include="..\Carrigan.SqlTools\Carrigan.SqlTools.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Carrigan.SqlTools.Clients.SqlServer.Tests" />
  </ItemGroup>

  <ItemGroup>
    <None Include="readme.md" Pack="true" PackagePath="\" />
    <None Include="Acknowledgements.txt" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
